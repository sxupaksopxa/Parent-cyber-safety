      "type": "single",
      "required": true,
      "options": ["yes", "no", "not_sure"]
    },
    {
      "id": "gaming_chat",
      "type": "single",
      "required": true,
      "options": [
        "yes_voice_chat",
        "yes_text_chat",
        "yes_chat_disabled",
        "no",
        "not_sure"
      ]
    },
    {
      "id": "public_wifi",
      "type": "single",
      "required": true,
      "options": ["often", "sometimes", "rarely", "never", "not_sure"]
    },
    {
      "id": "privacy_settings",
      "type": "single",
      "required": true,
      "options": ["yes", "partially", "no", "not_sure"]
    },
    {
      "id": "app_review",
      "type": "single",
      "required": true,
      "options": ["yes", "sometimes", "no"]
    },
    {
      "id": "online_incidents",
      "type": "single",
      "required": true,
      "options": ["yes", "maybe_not_sure", "no"]
    }
  ]
